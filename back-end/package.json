{
  "name": "domera-backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "clean:build-cache": "node -e \"const fs=require('fs'); ['dist','tsconfig.tsbuildinfo','tsconfig.build.tsbuildinfo'].forEach((p)=>{try{fs.rmSync(p,{recursive:true,force:true});}catch(e){}})\"",
    "start": "node dist/main.js",
    "start:dev": "npm run clean:build-cache && tsc-watch -p tsconfig.build.json --onSuccess \"node scripts/run-built.cjs\"",
    "build": "npm run clean:build-cache && tsc -p tsconfig.build.json",
    "lint": "eslint \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "status:sync": "node ../tools/generate-implementation-report.mjs"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.0",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.0",
    "@nestjs/platform-express": "^11.1.0",
    "@nestjs/swagger": "^11.1.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cookie": "^1.0.2",
    "firebase-admin": "^13.6.1",
    "resend": "^6.1.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "swagger-ui-express": "^5.0.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.7",
    "@types/cookie": "^1.0.0",
    "@types/express": "^5.0.1",
    "@types/multer": "^1.4.12",
    "@types/node": "^20.17.30",
    "eslint": "^9.25.1",
    "eslint-config-prettier": "^10.1.2",
    "tsc-watch": "^7.2.0",
    "typescript": "5.9.3"
  }
}